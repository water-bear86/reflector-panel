# Required for Supabase database access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for AES-256-GCM keypair encryption (base64-encoded 32-byte key)
# Generate with: openssl rand -base64 32
KEYPAIR_ENCRYPTION_KEY=your-base64-key

# Required for Vercel Cron authorization
CRON_SECRET=your-random-secret

# Optional — Helius RPC for reliable holder snapshots and pipeline execution
# Without this, distribute rules fall back to public Solana RPC (rate-limited)
HELIUS_API_KEY=your-helius-api-key

# Optional — Client-side Helius RPC (NEXT_PUBLIC_ prefix for browser access)
NEXT_PUBLIC_HELIUS_API_KEY=your-helius-api-key
